{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../../",
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "noEmit": false,
    "typeRoots": [
      "../../node_modules/@types",
      "../../node_modules"
    ]
  },
  "include": ["src/**/*", "../../packages/**/*"],
  "exclude": ["node_modules", "dist"]
}